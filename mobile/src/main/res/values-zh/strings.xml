    <!-- Compose setup wizard strings -->
    <string name="prism_setup_hero_title">欢迎使用 PrismSpace</string>
    <string name="prism_setup_hero_body">在同一台设备上安全运行另一份独立的应用副本。</string>
    <string name="prism_setup_features_title">主要功能</string>
    <string name="prism_setup_feature_clone_title">应用克隆</string>
    <string name="prism_setup_feature_clone_body">把已安装的应用复制到独立的双开空间，数据互不干扰。</string>
    <string name="prism_setup_feature_isolation_title">数据隔离</string>
    <string name="prism_setup_feature_isolation_body">双开空间使用独立的账号和存储，与主空间应用相互隔离。</string>
    <string name="prism_setup_feature_files_title">跨空间文件</string>
    <string name="prism_setup_feature_files_body">在主空间与双开空间之间，按需安全地传输文件。</string>
    <string name="prism_setup_privacy_title">工作原理 · 隐私</string>
    <string name="prism_setup_privacy_body">PrismSpace 通过 Android 工作资料创建双开空间。应用双开、安装和文件传输等核心流程在设备本地完成；检查更新、PrismProbe 网络测试和诊断分享只会在你主动使用时发起。</string>
    <string name="prism_setup_cta_primary">开始创建双开空间</string>
    <string name="prism_setup_cta_help">遇到问题？</string>
    <string name="prism_setup_error_title">无法继续</string>
    <string name="dialog_root_setup_profile_exists">设备上已存在 PrismSpace 双开空间。如需重新创建，请先在主空间中删除已有的双开空间，然后再次尝试设置。</string>
    <string name="setup_root_profile_progress">正在创建双开空间…</string>
    <string name="setup_error_managed_profile_not_supported">抱歉，此设备不支持必需的“Android 工作资料”特性。</string>
    <string name="setup_error_provisioning_incomplete">双开空间的创建不完整，此前的创建尝试可能并未成功。\n\n<b>如果您的设备或其它三方工具施加了“自启动”（或类似的）限制，请务必首先将棱镜空间解除限制或加入白名单，然后再次创建双开空间。</b></string>
    <string name="setup_error_managed_device">抱歉，由于此设备已被 <b>%1$s</b> 接管，双开空间无法创建。</string>
    <string name="setup_error_missing_managed_provisioning">抱歉，由于此设备并未完整支持必需的“Android 工作资料”特性。</string>
    <string name="setup_solution_for_cancelled_provision">创建双开空间遇到了困难？\n\n如果创建过程被中断，请重新进入系统创建流程，并确保棱镜空间允许后台启动。部分深度定制系统还需要先关闭电池优化或安全限制，然后再重试。\n\nRoot 创建只作为高级兜底路径，普通用户路径不依赖 Root。</string>


    <string name="button_setup_help">创建帮助</string>
    <string name="button_have_checked">我已检查</string>
    <string name="button_setup_space_with_root">通过 ROOT 创建双开空间</string>
    <string name="button_setup_space_with_dhizuku">通过 Dhizuku 创建双开空间</string>
    <string name="prism_help_setup_title">创建帮助</string>
    <string name="prism_help_setup_body">棱镜空间通过 Android 工作资料创建独立的双开空间。\n\n如果创建失败，先检查这些项目：\n· 允许棱镜空间后台运行和自启动。\n· 系统创建页面工作时不要手动关闭。\n· 关闭安全中心或电池策略对棱镜空间的限制后重试。\n· Root 创建仅作为普通创建被系统拦截后的高级兜底。</string>
    <string name="prism_help_clone_title">复制应用帮助</string>
    <string name="prism_help_clone_body">复制应用需要 Android 的已安装应用复制能力、可用的系统应用商店、Shizuku/ADB 授权，或棱镜空间安装器模块。\n\n如果当前路径被系统拦截，请先在主空间安装目标应用后再次复制，或在设置里启用 Shizuku/ADB 模式。</string>
    <string name="prism_help_main_space_title">管理主空间</string>
    <string name="prism_help_main_space_body">管理主空间会让棱镜空间获得整机范围的管理能力，不只是双开空间能力。只有当你需要冻结主空间应用、或把 ADB 安全限制应用到整台设备时才需要启用。\n\n这是可选能力。复制和启动双开应用不需要管理主空间。</string>

    <string name="action_rescind">撤销</string>



    <string name="dialog_title_warning">注意</string>
    <string name="dialog_reactivate_message">双开空间入口被意外关闭，请再次授予设备管理权限以重新开启。</string>
    <string name="dialog_destroy_message">确定要删除整个双开空间？其中的应用副本和所有数据将被永久删除，无法恢复。\n\n主空间的应用和数据不会受到影响。</string>
    <string name="dialog_destroy_message_for_managed_user">如果“主空间”也由棱镜空间管理，由于 Android 系统施加的限制，您将无法再创建新的双开空间，除非撤销对“主空间”的管理权。\n\n确定仍要删除此双开空间？</string>
    <string name="dialog_rescind_message">确定要撤销对“主空间”的管理权？\n\n将来若希望重新启用，必须再一次完成必要的流程。如果没有 ROOT 权限，届时需要删除现有的双开空间（如果已创建）并退出设备上登录的所有账号。</string>
    <string name="dialog_cannot_destroy_message">如果要删除整个双开空间，请打开系统设置 -（用户和）账号，点选“移除工作资料”。</string>
    <string name="dialog_critical_app_warning">这个应用（或组件）可能对于 Android 系统或其它应用的正常运作至关重要。如果继续此操作，部分应用甚至整个系统可能因此变得不稳定或无法正常运作。\n\n确认继续？</string>
    <string name="dialog_space_setup_failed">抱歉，创建双开空间时出现了异常。（阶段 %1$d）</string>

